rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasProfile() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isApproved() {
      return hasProfile() && userDoc().status == 'approved';
    }

    function isAdmin() {
      return isApproved() && userDoc().role == 'admin';
    }

    function sameRestaurant(restaurantId) {
      return isApproved() && userDoc().restaurantId == restaurantId;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function batchData(batchId) {
      return get(/databases/$(database)/documents/inventoryBatches/$(batchId)).data;
    }

    function isValidWasteReason(reason) {
      return reason in ['Expired', 'Burnt', 'Prep Waste', 'Leftovers'];
    }

    match /restaurantCodes/{code} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.restaurantId is string
        && request.resource.data.code == code
        && request.resource.data.name is string;
      allow update, delete: if false;
    }

    match /restaurants/{restaurantId} {
      allow get: if isApproved() && sameRestaurant(restaurantId);
      allow list: if false;
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.code is string;
      // Admin may update expiryAlertThreshold (FR-025); core identity fields stay immutable.
      allow update: if isAdmin()
        && sameRestaurant(restaurantId)
        && request.resource.data.name == resource.data.name
        && request.resource.data.code == resource.data.code
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.expiryAlertThreshold is int
        && request.resource.data.expiryAlertThreshold >= 1
        && request.resource.data.expiryAlertThreshold <= 30;
      allow delete: if false;
    }

    match /users/{userId} {
      allow read: if isOwner(userId)
        || (isAdmin() && resource.data.restaurantId == userDoc().restaurantId);

      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && request.resource.data.restaurantId is string
        && request.resource.data.restaurantCode is string
        && request.resource.data.restaurantName is string
        && (
          (
            request.resource.data.role == 'admin'
            && request.resource.data.status == 'approved'
          )
          || (
            request.resource.data.role == 'staff'
            && request.resource.data.status == 'pending'
            && exists(/databases/$(database)/documents/restaurants/$(request.resource.data.restaurantId))
          )
        );

      allow update: if (
          isOwner(userId)
          && request.resource.data.role == resource.data.role
          && request.resource.data.status == resource.data.status
          && request.resource.data.restaurantId == resource.data.restaurantId
          && request.resource.data.restaurantCode == resource.data.restaurantCode
        )
        || (
          isAdmin()
          && resource.data.role == 'staff'
          && resource.data.restaurantId == userDoc().restaurantId
          && request.resource.data.role == 'staff'
          && request.resource.data.restaurantId == resource.data.restaurantId
          && request.resource.data.status in ['approved', 'rejected', 'deactivated', 'pending']
        );

      allow delete: if false;
    }

    match /costs/{docId} {
      // FR-035 — admin-only financial collection
      allow read: if isAdmin()
        && resource.data.restaurantId == userDoc().restaurantId;
      allow create: if isAdmin()
        && request.resource.data.restaurantId == userDoc().restaurantId;
      allow update: if isAdmin()
        && resource.data.restaurantId == userDoc().restaurantId
        && request.resource.data.restaurantId == resource.data.restaurantId;
      allow delete: if false;
    }

    match /analytics/{docId} {
      allow read: if isAdmin()
        && resource.data.restaurantId == userDoc().restaurantId;
      allow create: if isAdmin()
        && request.resource.data.restaurantId == userDoc().restaurantId;
      allow update: if isAdmin()
        && resource.data.restaurantId == userDoc().restaurantId
        && request.resource.data.restaurantId == resource.data.restaurantId;
      allow delete: if false;
    }

    // FR-035 — financial summaries are admin-read; clients cannot write (no tampering).
    match /financialSummaries/{restaurantId} {
      allow read: if isAdmin() && sameRestaurant(restaurantId);
      allow create, update, delete: if false;
    }

    // Inventory batches (FR-011–FR-020)
    match /inventoryBatches/{docId} {
      allow read: if isApproved()
        && resource.data.restaurantId == userDoc().restaurantId;

      allow create: if isApproved()
        && request.resource.data.restaurantId == userDoc().restaurantId
        && request.resource.data.ingredientName is string
        && request.resource.data.quantity is number
        && request.resource.data.quantity > 0
        && request.resource.data.unitCost is number
        && request.resource.data.unitCost >= 0
        && request.resource.data.consumed == false
        && request.resource.data.archived == false
        && request.resource.data.createdBy == request.auth.uid;

      // Staff/admin can update same-restaurant batches.
      // Only admins may change the archived flag (FR-019).
      // Evaluation/notification fields are Cloud Functions–owned (Admin SDK).
      allow update: if isApproved()
        && resource.data.restaurantId == userDoc().restaurantId
        && request.resource.data.restaurantId == resource.data.restaurantId
        && request.resource.data.ingredientName == resource.data.ingredientName
        && request.resource.data.unitCost == resource.data.unitCost
        && request.resource.data.unit == resource.data.unit
        && request.resource.data.dateReceived == resource.data.dateReceived
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.get('evaluatedTone', null) == resource.data.get('evaluatedTone', null)
        && request.resource.data.get('lastNotifiedTone', null) == resource.data.get('lastNotifiedTone', null)
        && request.resource.data.get('lastNotifiedAt', null) == resource.data.get('lastNotifiedAt', null)
        && request.resource.data.get('lastEvaluatedAt', null) == resource.data.get('lastEvaluatedAt', null)
        && (
          isAdmin()
          || request.resource.data.archived == resource.data.archived
        );

      allow delete: if false;
    }

    match /auditLogs/{docId} {
      allow read: if isAdmin()
        && resource.data.restaurantId == userDoc().restaurantId;
      allow create: if isApproved()
        && request.resource.data.restaurantId == userDoc().restaurantId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.action in [
          'batch_created',
          'batch_edited',
          'batch_consumed',
          'batch_archived',
          'threshold_updated',
          'waste_created',
          'waste_voided',
          'inventory_restored'
        ];
      allow update, delete: if false;
    }

    // User inbox — created only by Cloud Functions (Admin SDK).
    match /notifications/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if false;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.batchId == resource.data.batchId
        && request.resource.data.restaurantId == resource.data.restaurantId;
      allow delete: if false;
    }

    // Restaurant-wide dispatch audit — Functions write only.
    match /notificationHistory/{docId} {
      allow read: if isAdmin()
        && resource.data.restaurantId == userDoc().restaurantId;
      allow create, update, delete: if false;
    }

    // Waste logs (FR-026–FR-031). Prefer Cloud Functions; client fallback allowed with strict checks.
    match /wasteLogs/{docId} {
      allow read: if isApproved()
        && resource.data.restaurantId == userDoc().restaurantId;

      allow create: if isApproved()
        && request.resource.data.restaurantId == userDoc().restaurantId
        && request.resource.data.loggedBy == request.auth.uid
        && request.resource.data.voided == false
        && request.resource.data.voidedAt == null
        && request.resource.data.voidedBy == null
        && request.resource.data.quantityWasted is number
        && request.resource.data.quantityWasted > 0
        && request.resource.data.unitCost is number
        && request.resource.data.unitCost >= 0
        && request.resource.data.costLoss is number
        && request.resource.data.costLoss ==
          request.resource.data.quantityWasted * request.resource.data.unitCost
        && isValidWasteReason(request.resource.data.wasteReason)
        && exists(/databases/$(database)/documents/inventoryBatches/$(request.resource.data.batchId))
        && batchData(request.resource.data.batchId).restaurantId == userDoc().restaurantId
        && batchData(request.resource.data.batchId).archived == false
        && batchData(request.resource.data.batchId).consumed == false
        && request.resource.data.quantityWasted <= batchData(request.resource.data.batchId).quantity
        && request.resource.data.unitCost == batchData(request.resource.data.batchId).unitCost
        && request.resource.data.ingredientName == batchData(request.resource.data.batchId).ingredientName
        && request.resource.data.unit == batchData(request.resource.data.batchId).unit;

      // Admin void only — cannot alter financial/identity fields.
      allow update: if isAdmin()
        && resource.data.restaurantId == userDoc().restaurantId
        && resource.data.voided == false
        && request.resource.data.voided == true
        && request.resource.data.voidedBy == request.auth.uid
        && request.resource.data.restaurantId == resource.data.restaurantId
        && request.resource.data.batchId == resource.data.batchId
        && request.resource.data.ingredientName == resource.data.ingredientName
        && request.resource.data.quantityWasted == resource.data.quantityWasted
        && request.resource.data.unit == resource.data.unit
        && request.resource.data.wasteReason == resource.data.wasteReason
        && request.resource.data.unitCost == resource.data.unitCost
        && request.resource.data.costLoss == resource.data.costLoss
        && request.resource.data.loggedBy == resource.data.loggedBy
        && request.resource.data.timestamp == resource.data.timestamp
        && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if false;
    }

    // Legacy collection name — locked down.
    match /waste/{docId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
