# =============================================================================
# PUBLIC (safe to embed in the mobile/web client via EXPO_PUBLIC_*)
# Firebase web/Android config is designed to be public; protect data with Rules.
# =============================================================================
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Optional: Cloud Functions region (defaults to us-central1)
EXPO_PUBLIC_FIREBASE_FUNCTIONS_REGION=us-central1

# =============================================================================
# PRIVATE — set only in Cloud Functions / CI secrets, NEVER in the mobile app
# Copy GEMINI_API_KEY into functions/.env (see functions/.env.example)
# =============================================================================
# GEMINI_API_KEY=
